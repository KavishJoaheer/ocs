# Your public Docker Hub username.
DOCKERHUB_USERNAME=your-dockerhub-username

# Docker Hub repository name for this app image.
APP_IMAGE_NAME=clinicflow

# LAN port on the NAS that will expose the website.
APP_PORT=8080

# Match the clinic timezone so reports and schedules line up.
TZ=Indian/Mauritius

# Web Push (VAPID) — run `npm run generate-vapid` in server/ to create a key pair.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@ocs.local

# How often Watchtower checks Docker Hub for a newer image, in seconds.
WATCHTOWER_POLL_INTERVAL=300

# Upsert master warehouse stock from server/src/config/ocsMasterStockData.js on each app start.
# Set to false after go-live if operators manage quantities manually and you do not want spreadsheet sync.
SEED_OCS_MASTER_STOCK=false

# Mirror OCS master stock catalog into every doctor medical bag on each app start.
# Set to true only for initial catalog setup or disaster recovery.
SEED_DOCTOR_STOCK_FROM_OCS=false

# --- Cloudflare (optional; use one tunnel type only) ---

# Quick tunnel only: upstream URL inside Docker (default matches app service name).
CLOUDFLARE_TUNNEL_URL=http://clinicflow-app:3001

# Named tunnel (custom domain): token from Cloudflare Zero Trust → Networks → Tunnels → your tunnel → Docker install command.
# Used by docker-compose.cloudflare.named.yml only.
TUNNEL_TOKEN=
